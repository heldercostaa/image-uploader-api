# Node
TZ="UTC"

# Api
NODE_ENV="development"
PORT="3333"

# Database
# If running from "pnpm dev", point HOST to localhost. eg: postgresql://postgres:postgres@localhost:5432/planner
# If running from docker, point HOST to postgres. eg: postgresql://postgres:postgres@postgres:5432/planner
DB_URL="postgresql://postgres:postgres@postgres:5432/image_uploader"

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKET=""
CLOUDFLARE_PUBLIC_URL=""
